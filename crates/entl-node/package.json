{
  "name": "@entl/node",
  "version": "0.0.0",
  "description": "The entl engine (git + GitHub -> DuckDB) as an in-process Node/Bun native addon.",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "entl"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "gen": "bash ../../scripts/gen.sh",
    "test": "bun test",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@electric-sql/pglite": "^0.5.3",
    "@napi-rs/cli": "^3.7.3",
    "apache-arrow": "^21.1.0",
    "drizzle-orm": "^0.45.2"
  }
}
